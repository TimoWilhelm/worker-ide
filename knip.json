{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"ignoreExportsUsedInFile": {
		"interface": true,
		"type": true
	},
	"exclude": ["types"],
	"entry": ["worker/index.ts", "auxiliary/biome/index.ts", "auxiliary/esbuild/index.ts"],
	"project": ["src/**", "worker/**", "auxiliary/**", "shared/**", "test/**"],
	"ignoreDependencies": ["cloudflare", "codemirror", "@standard-schema/spec"],
	"ignoreFiles": [
		"src/vite-env.d.ts",
		"playwright.config.ts",
		"shared/ws-messages.ts",
		"src/components/ui/index.ts",
		"worker/lib/preview-scripts/*.js"
	],
	"ignoreWorkspaces": ["landing"]
}
