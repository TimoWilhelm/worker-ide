{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"ignoreExportsUsedInFile": {
		"interface": true,
		"type": true
	},
	"exclude": ["types"],
	"workspaces": {
		".": {
			"entry": ["worker/index.ts"],
			"project": ["src/**", "worker/**", "test/**"],
			"ignoreDependencies": ["cloudflare", "codemirror", "@standard-schema/spec"],
			"ignoreFiles": ["src/vite-env.d.ts", "playwright.config.ts", "src/components/ui/index.ts", "worker/lib/preview-scripts/*.js"]
		},
		"shared": {
			"entry": ["**/*.ts", "!**/*.test.ts"],
			"project": ["**/*.ts"]
		},
		"auxiliary/biome": {
			"entry": ["index.ts"],
			"project": ["**/*.ts", "!**/*.test.ts"]
		},
		"auxiliary/esbuild": {
			"entry": ["index.ts"],
			"project": ["**/*.ts", "!**/*.test.ts"]
		},
		"landing": {
			"entry": ["src/pages/**/*.astro"],
			"project": ["src/**/*.{astro,ts,tsx}"]
		}
	}
}
