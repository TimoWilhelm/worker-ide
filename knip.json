{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"ignoreExportsUsedInFile": {
		"interface": true,
		"type": true
	},
	"exclude": ["types"],
	"entry": ["auxiliary/biome/index.ts", "auxiliary/esbuild/index.ts", "auxiliary/git/index.ts", "shared/**/*.ts", "!shared/**/*.test.ts"],
	"project": ["src/**", "worker/**", "shared/**", "auxiliary/**", "test/**"],
	"ignoreDependencies": ["cloudflare", "codemirror", "@standard-schema/spec"],
	"ignoreFiles": ["worker/drizzle/migrations.d.ts", "auxiliary/*/worker-configuration.d.ts"]
}
