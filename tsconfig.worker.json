{
	"extends": "./tsconfig.node.json",
	"compilerOptions": {
		"composite": true,
		"noEmit": false,
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"outDir": "./dist/worker",
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.worker.tsbuildinfo",
		"lib": ["ES2024"],
		"paths": {
			"@shared/*": ["./shared/*"],
			"@git/*": ["./auxiliary/git/*"],
			"@worker/*": ["./worker/*"]
		},
		"types": ["./worker-configuration.d.ts", "./raw-minified.d.ts", "vite/client", "node"]
	},
	"include": ["worker", "shared", "auxiliary", "auxiliary/git/drizzle/**/*.js", "auxiliary/git/drizzle/**/*.json"],
	"exclude": [
		"worker/fixtures",
		"worker/migrations/do-agent/*.js",
		"worker/migrations/do-agent/*.sql",
		"worker/migrations/d1-auth/*.sql",
		"worker/**/*.test.ts",
		"shared/**/*.test.ts",
		"auxiliary/**/*.test.ts"
	]
}
