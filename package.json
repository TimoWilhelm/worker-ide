		"workers-ai-provider": "^3.1.8",
		"wrangler": "^4.77.0",
		"zod": "^4.3.6",
		"zustand": "^5.0.12"
	},
	"overrides": {
		"worker-fs-mount": "^0.1.1",
		"zod-validation-error": "^5.0.0",
		"@vitest/expect": "3.2.4",
		"@vitest/spy": "3.2.4",
		"@codemirror/view": "6.40.0",
		"@codemirror/language": "6.12.2",
		"@codemirror/state": "6.6.0",
		"@codemirror/autocomplete": "6.20.1",
		"@codemirror/lint": "6.9.5",
		"@codemirror/lang-javascript": "6.2.5"
	},
	"packageManager": "bun@1.3.9",
	"private": true,
	"scripts": {
		"postinstall": "bun scripts/vendor-wasm.ts",
		"prepare": "husky",
		"dev": "bun run build:worker-types && concurrently -n vite,types -c blue,yellow \"vite --port 3000\" \"tsc -p tsconfig.worker.json --watch --preserveWatchOutput\"",
		"build": "turbo run build:vite",
		"build:worker-types": "tsc -p tsconfig.worker.json",
		"build:vite": "vite build",
		"typecheck": "turbo run typecheck:app typecheck:node typecheck:worker typecheck:scripts",
		"typecheck:app": "tsc --noEmit -p tsconfig.app.json",
		"typecheck:node": "tsc --noEmit -p tsconfig.node.json",
		"typecheck:worker": "tsc --noEmit -p tsconfig.worker.json",
		"typecheck:scripts": "tsc --noEmit -p tsconfig.scripts.json",
		"lint": "prettier --check . && eslint --cache --format=stylish .",
		"format": "prettier --write . && eslint --cache --format=stylish --fix .",
		"test": "vitest",
		"test:unit": "vitest --project unit",
		"test:worker": "vitest --project worker",
		"test:react": "vitest --project react",
		"test:integration": "vitest run --config test/integration/vitest.config.ts",
		"test:storybook": "vitest run --config .storybook/vitest.config.ts",
		"test:e2e": "playwright test",
		"test:e2e:report": "playwright show-report",
		"preview": "turbo run build:vite && vite preview --host 0.0.0.0 --port 4173",
		"deploy": "turbo run build:vite && wrangler d1 migrations apply worker-ide-auth --remote && wrangler deploy -c dist/biome_worker/wrangler.json && wrangler deploy -c dist/esbuild_worker/wrangler.json && wrangler deploy -c dist/git_worker/wrangler.json && wrangler deploy --no-bundle",
		"cf-typegen": "bun run scripts/generate-types.ts",
		"db:generate": "drizzle-kit generate --config drizzle-d1.config.ts",
		"db:migrate:local": "wrangler d1 migrations apply worker-ide-auth --local",
		"db:migrate:remote": "wrangler d1 migrations apply worker-ide-auth --remote",
		"knip": "knip",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	}
}
