---
const appUrl = 'https://codemaxxing.app';
---

<section id="cta" class="relative py-24 sm:py-32">
	<div class="mx-auto max-w-6xl px-6">
		<div class="grain relative overflow-hidden rounded-2xl border border-border bg-bg-secondary/40 p-10 backdrop-blur-sm sm:p-16">
			<!-- Atmospheric glow blobs — asymmetric -->
			<div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
				<div
					class="absolute -top-1/3 -right-1/4 h-[400px] w-[400px] rounded-full opacity-25 blur-[100px]"
					style="background: var(--color-accent);"
				>
				</div>
				<div
					class="absolute -bottom-1/4 -left-1/3 h-[350px] w-[350px] rounded-full opacity-15 blur-[100px]"
					style="background: var(--color-accent);"
				>
				</div>
			</div>

			<div class="relative text-center">
				<p class="mb-4 font-mono text-xs uppercase tracking-widest text-accent">Get Started</p>
				<h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Ready to build something?</h2>
				<p class="mx-auto mt-4 max-w-xl text-lg leading-relaxed text-text-secondary">
					Open the IDE and start coding in seconds. No signup wall, no credit card, no configuration. Just you and your code.
				</p>
				<div class="mt-10">
					<a
						href={appUrl}
						class="border-beam inline-flex items-center gap-2 rounded-full bg-accent px-8 py-3.5 text-base font-bold text-white animate-glow-pulse transition-all hover:brightness-110"
					>
						Launch the IDE
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="18"
							height="18"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2.5"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<path d="M5 12h14"></path>
							<path d="m12 5 7 7-7 7"></path>
						</svg>
					</a>
				</div>
			</div>
		</div>
	</div>
</section>
