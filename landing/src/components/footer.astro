---
const currentYear = new Date().getFullYear();
const appUrl = 'https://codemaxxing.app';
---

<!-- Gradient fade separator -->
<div
	class="h-px"
	style="background: linear-gradient(90deg, transparent, var(--color-border-solid) 30%, var(--color-border-solid) 70%, transparent);"
	aria-hidden="true"
>
</div>

<footer class="py-10">
	<div class="mx-auto max-w-6xl px-6">
		<div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
			<!-- Logo -->
			<a href="/" class="flex items-center gap-2 text-sm font-semibold tracking-tight">
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="18"
					height="18"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.5"
					stroke-linecap="round"
					stroke-linejoin="round"
					class="text-accent"
				>
					<path
						d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"
					></path>
				</svg>
				<span>Codemaxxing</span>
			</a>

			<!-- Links -->
			<div class="flex items-center gap-6 font-mono text-xs uppercase tracking-widest text-text-secondary">
				<a href={appUrl} class="transition-colors hover:text-accent"> Open IDE </a>
				<a href="#features" class="transition-colors hover:text-accent"> Features </a>
				<a
					href="https://github.com/anomalyco/worker-ide"
					class="transition-colors hover:text-accent"
					target="_blank"
					rel="noopener noreferrer"
				>
					GitHub
				</a>
			</div>

			<!-- Copyright -->
			<p class="text-xs text-text-secondary">
				&copy; {currentYear} Codemaxxing.ai
			</p>
		</div>
	</div>
</footer>
